{
	"name": "@xsyetopz/rscheck-site",
	"version": "0.1.0",
	"description": "Site and frontend tooling for rscheck",
	"type": "module",
	"private": true,
	"scripts": {
		"site:dev": "vite --config site/vite.config.ts",
		"site:build": "vite build --config site/vite.config.ts",
		"site:preview": "vite preview --config site/vite.config.ts",
		"dev": "vite --config site/vite.config.ts",
		"build": "vite build --config site/vite.config.ts",
		"preview": "vite preview --config site/vite.config.ts",
		"typecheck": "bunx tsc --noEmit",
		"typecheck:build": "bunx tsc -p tsconfig.build.json --noEmit",
		"biome:check": "bunx biome check . --max-diagnostics 16384",
		"biome:format": "bunx biome format . --write --max-diagnostics 16384",
		"biome:lint": "bunx biome lint . --write --max-diagnostics 16384"
	},
	"author": {
		"name": "xsyetopz"
	},
	"license": "MIT OR Apache-2.0",
	"repository": {
		"type": "git",
		"url": "https://github.com/xsyetopz/rscheck.git"
	},
	"homepage": "https://xsyetopz.github.io/rscheck/",
	"devDependencies": {
		"@biomejs/biome": "^2.4.11",
		"@fontsource/jetbrains-mono": "^5.2.8",
		"@fontsource/space-grotesk": "^5.2.10",
		"@mantine/code-highlight": "^9.0.1",
		"@mantine/core": "^9.0.1",
		"@mantine/hooks": "^9.0.1",
		"@tabler/icons-react": "^3.41.1",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@types/bun": "^1.3.12",
		"@vitejs/plugin-react": "^6.0.1",
		"bun-types": "^1.3.12",
		"highlight.js": "^11.11.1",
		"postcss": "^8.5.9",
		"postcss-preset-mantine": "^1.18.0",
		"react": "^19.2.5",
		"react-dom": "^19.2.5",
		"typescript": "6.0.2",
		"vite": "^8.0.8"
	}
}
